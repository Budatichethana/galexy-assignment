generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Existing workflow model (previously stored in plain PostgreSQL)
model Workflow {
  id        String   @id
  userId    String
  name      String?
  nodes     Json
  edges     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runs      WorkflowRun[]
}

// Track each workflow execution
model WorkflowRun {
  id          String   @id @default(cuid())
  workflowId  String
  userId      String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String   @db.VarChar(50) // "running", "success", "failed"
  startedAt   DateTime @default(now())
  completedAt DateTime?
  nodeRuns    NodeRun[]
  createdAt   DateTime @default(now())

  @@index([workflowId])
  @@index([status])
}

// Track each node execution within a workflow run
model NodeRun {
  id          String   @id @default(cuid())
  runId       String
  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId      String
  nodeType    String   @db.VarChar(50)
  status      String   @db.VarChar(50) // "running", "success", "failed"
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([runId])
  @@index([nodeId])
  @@index([status])
}
